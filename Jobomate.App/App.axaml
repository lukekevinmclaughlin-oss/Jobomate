<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Jobomate.App"
             Name="Jobomate"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />

    <Style Selector="Window">
      <Setter Property="FontFamily" Value="SF Pro Text, .SF NS Text, Segoe UI, Arial" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource TahoeTextBrush}" />
    </Style>

    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="SF Pro Text, .SF NS Text, Segoe UI, Arial" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource TahoeTextBrush}" />
    </Style>

    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="{DynamicResource TahoeMutedTextBrush}" />
    </Style>

    <Style Selector="TextBlock.heading">
      <Setter Property="FontSize" Value="17" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="FontFamily" Value="SF Pro Text, .SF NS Text, Segoe UI, Arial" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource TahoeTextBrush}" />
      <Setter Property="Background" Value="{DynamicResource TahoeInputBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderBrush}" />
      <Setter Property="CaretBrush" Value="{DynamicResource TahoeTextBrush}" />
      <Setter Property="SelectionBrush" Value="#663B82F6" />
      <Setter Property="SelectionForegroundBrush" Value="#FFFFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="MinHeight" Value="50" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18">
            <BrushTransition.Easing>
              <SplineEasing X1="0.4" Y1="0" X2="0.2" Y2="1" />
            </BrushTransition.Easing>
          </BrushTransition>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18">
            <BrushTransition.Easing>
              <SplineEasing X1="0.4" Y1="0" X2="0.2" Y2="1" />
            </BrushTransition.Easing>
          </BrushTransition>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource CursorFocusRingBrush}" />
      <Setter Property="Background" Value="{DynamicResource TahoeInputBrush}" />
    </Style>

    <Style Selector="TextBox.cursor-prompt-input">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="#303030" />
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style Selector="TextBox.cursor-prompt-input:focus">
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <!-- PERMANENT grey: FluentTheme drives the TextBox background from
         TextControlBackground{,PointerOver,Focused} (all #000000 here), which would otherwise turn the
         prompt input black the moment it is hovered/focused. Pin the template's border element grey in
         EVERY state so the chat prompt area keeps its grey fill at rest, on hover, and while typing. -->
    <Style Selector="TextBox.cursor-prompt-input /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="#303030" />
    </Style>
    <Style Selector="TextBox.cursor-prompt-input:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="#303030" />
    </Style>
    <Style Selector="TextBox.cursor-prompt-input:focus /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="#303030" />
    </Style>
    <Style Selector="TextBox.cursor-prompt-input:focus-within /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="#303030" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="FontFamily" Value="SF Pro Text, .SF NS Text, Segoe UI, Arial" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource TahoeTextBrush}" />
      <Setter Property="Background" Value="{DynamicResource TahoeInputBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style Selector="ComboBox:pointerover">
      <Setter Property="Background" Value="{DynamicResource TahoeButtonHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderHoverBrush}" />
    </Style>

    <Style Selector="ToolTip">
      <Setter Property="Background" Value="#27272A" />
      <Setter Property="Foreground" Value="#FAFAFA" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontFamily" Value="SF Pro Text, .SF NS Text, Segoe UI, Arial" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Padding" Value="10,7" />
    </Style>

    <Style Selector="ToolTip TextBlock">
      <Setter Property="Foreground" Value="#FAFAFA" />
    </Style>

    <Style Selector="Button">
      <Setter Property="FontFamily" Value="SF Pro Text, .SF NS Text, Segoe UI, Arial" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TahoeTextBrush}" />
      <Setter Property="Background" Value="{DynamicResource TahoeButtonBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="14,9" />
      <Setter Property="MinWidth" Value="48" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18">
            <BrushTransition.Easing>
              <SplineEasing X1="0.4" Y1="0" X2="0.2" Y2="1" />
            </BrushTransition.Easing>
          </BrushTransition>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18">
            <BrushTransition.Easing>
              <SplineEasing X1="0.4" Y1="0" X2="0.2" Y2="1" />
            </BrushTransition.Easing>
          </BrushTransition>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18">
            <DoubleTransition.Easing>
              <SplineEasing X1="0.4" Y1="0" X2="0.2" Y2="1" />
            </DoubleTransition.Easing>
          </DoubleTransition>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{DynamicResource TahoeButtonHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderHoverBrush}" />
    </Style>

    <Style Selector="Button:focus, ToggleButton:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource CursorFocusRingBrush}" />
    </Style>

    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="{DynamicResource TahoeButtonPressedBrush}" />
    </Style>

    <Style Selector="Button.tahoe-pill">
      <Setter Property="Background" Value="{DynamicResource TahoePillBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="MinHeight" Value="32" />
    </Style>

    <Style Selector="Button.tahoe-pill:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderHoverBrush}" />
    </Style>

    <Style Selector="Button.tahoe-icon, ToggleButton.tahoe-icon">
      <Setter Property="Width" Value="40" />
      <Setter Property="Height" Value="40" />
      <Setter Property="MinWidth" Value="40" />
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="Padding" Value="9" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Background" Value="{DynamicResource TahoeIconButtonBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18">
            <BrushTransition.Easing>
              <SplineEasing X1="0.4" Y1="0" X2="0.2" Y2="1" />
            </BrushTransition.Easing>
          </BrushTransition>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18">
            <BrushTransition.Easing>
              <SplineEasing X1="0.4" Y1="0" X2="0.2" Y2="1" />
            </BrushTransition.Easing>
          </BrushTransition>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button.tahoe-icon:pointerover, ToggleButton.tahoe-icon:pointerover">
      <Setter Property="Background" Value="{DynamicResource TahoeButtonHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderHoverBrush}" />
    </Style>

    <!-- Slim ghost button used in sidecar chrome (collapse / close). Transparent by default,
         subtle hover. Replaces the typewritten "..." and "x" buttons that looked amateurish. -->
    <Style Selector="Button.sidecar-chrome">
      <Setter Property="Width" Value="28" />
      <Setter Property="Height" Value="28" />
      <Setter Property="MinWidth" Value="28" />
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="Padding" Value="6" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.sidecar-chrome:pointerover">
      <Setter Property="Background" Value="#1A8A9AB0" />
    </Style>
    <Style Selector="Button.sidecar-chrome:pressed">
      <Setter Property="Background" Value="#2A8A9AB0" />
    </Style>

    <!-- Small icon-only chip used on user chat bubbles for the inline Edit affordance.
         Lighter than BubbleActionButton (which is still used for Cancel/Send in edit mode). -->
    <Style Selector="Button.bubble-affordance">
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="26" />
      <Setter Property="MinWidth" Value="26" />
      <Setter Property="MinHeight" Value="26" />
      <Setter Property="Padding" Value="5" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Background" Value="#11000000" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.bubble-affordance:pointerover">
      <Setter Property="Background" Value="#220A84FF" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorFocusRingBrush}" />
    </Style>
    <Style Selector="Button.bubble-affordance:pressed">
      <Setter Property="Background" Value="#330A84FF" />
    </Style>

    <Style Selector="Button.codex-tool-icon, ToggleButton.codex-tool-icon">
      <Setter Property="Width" Value="36" />
      <Setter Property="Height" Value="36" />
      <Setter Property="MinWidth" Value="36" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Background" Value="{DynamicResource TahoeIconButtonBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#6B7280" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18">
            <BrushTransition.Easing>
              <SplineEasing X1="0.4" Y1="0" X2="0.2" Y2="1" />
            </BrushTransition.Easing>
          </BrushTransition>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18">
            <BrushTransition.Easing>
              <SplineEasing X1="0.4" Y1="0" X2="0.2" Y2="1" />
            </BrushTransition.Easing>
          </BrushTransition>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button.codex-tool-icon:pointerover, ToggleButton.codex-tool-icon:pointerover">
      <Setter Property="Background" Value="{DynamicResource TahoeButtonHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderHoverBrush}" />
    </Style>

    <Style Selector="Button.codex-tool-icon:pressed, ToggleButton.codex-tool-icon:pressed">
      <Setter Property="Background" Value="#E1EEFF" />
    </Style>

    <Style Selector="Button.codex-card">
      <Setter Property="Width" Value="236" />
      <Setter Property="Height" Value="150" />
      <Setter Property="Padding" Value="18" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Background" Value="#48182230" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="1.4" />
      <Setter Property="Foreground" Value="#F8FAFC" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.2">
            <BrushTransition.Easing>
              <SplineEasing X1="0.4" Y1="0" X2="0.2" Y2="1" />
            </BrushTransition.Easing>
          </BrushTransition>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.2">
            <BrushTransition.Easing>
              <SplineEasing X1="0.4" Y1="0" X2="0.2" Y2="1" />
            </BrushTransition.Easing>
          </BrushTransition>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button.codex-card:pointerover">
      <Setter Property="Background" Value="#60202A3A" />
      <Setter Property="BorderBrush" Value="#00000000" />
    </Style>

    <Style Selector="Button.codex-card.bento-primary">
      <Setter Property="Width" Value="236" />
      <Setter Property="Height" Value="150" />
    </Style>

    <Style Selector="Button.codex-card.bento-compact">
      <Setter Property="Width" Value="236" />
      <Setter Property="Height" Value="150" />
    </Style>

    <Style Selector="Border.codex-surface">
      <Setter Property="Background" Value="#28FFFFFF" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style Selector="ToggleButton.tahoe-icon:checked">
      <Setter Property="Background" Value="{DynamicResource TahoeButtonPressedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TahoeButtonBorderBrush}" />
    </Style>

    <Style Selector="ToggleButton.pane-toggle:checked">
      <Setter Property="Background" Value="{DynamicResource TahoeButtonPressedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TahoeButtonBorderBrush}" />
    </Style>

    <Style Selector="ToggleButton.pane-toggle:checked Path">
      <Setter Property="Fill" Value="#334155" />
    </Style>

    <Style Selector="ToggleButton.pane-toggle:checked /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource TahoeButtonPressedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TahoeButtonBorderBrush}" />
    </Style>

    <Style Selector="ToggleButton.codex-tool-icon:checked /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource TahoeButtonPressedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TahoeButtonBorderBrush}" />
    </Style>

    <Style Selector="Button.traffic">
      <Setter Property="Width" Value="12" />
      <Setter Property="Height" Value="12" />
      <Setter Property="MinWidth" Value="12" />
      <Setter Property="MinHeight" Value="12" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="8" />
      <Setter Property="Foreground" Value="#80000000" />
    </Style>

    <Style Selector="MenuItem">
      <Setter Property="FontFamily" Value="SF Pro Text, .SF NS Text, Segoe UI, Arial" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource TahoeTextBrush}" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="MenuItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource TahoeButtonHoverBrush}" />
    </Style>

    <Style Selector="ContextMenu">
      <Setter Property="Background" Value="#1C1C1C" />
      <Setter Property="BorderBrush" Value="#3A3A3A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="4" />
    </Style>

    <Style Selector="MenuFlyoutPresenter">
      <Setter Property="Background" Value="#1C1C1C" />
      <Setter Property="BorderBrush" Value="#3A3A3A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="4" />
    </Style>

    <Style Selector="FlyoutPresenter">
      <Setter Property="Background" Value="#1C1C1C" />
      <Setter Property="BorderBrush" Value="#3A3A3A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="4" />
    </Style>

    <Style Selector="ToggleButton">
      <Setter Property="FontFamily" Value="SF Pro Text, .SF NS Text, Segoe UI, Arial" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TahoeTextBrush}" />
      <Setter Property="Background" Value="{DynamicResource TahoeButtonBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="ToggleButton:pointerover">
      <Setter Property="Background" Value="{DynamicResource TahoeButtonHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderHoverBrush}" />
    </Style>

    <Style Selector="Border.cursor-frame">
      <Setter Property="BorderBrush" Value="{DynamicResource CursorFrameBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.cursor-frame:focus-within">
      <Setter Property="BorderBrush" Value="#00000000" />
    </Style>

    <Style Selector="Border.cursor-subframe">
      <Setter Property="BorderBrush" Value="{DynamicResource CursorControlBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.cursor-chat-user">
      <Setter Property="BorderBrush" Value="{DynamicResource CursorChatUserBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.cursor-chat-assistant">
      <Setter Property="BorderBrush" Value="{DynamicResource CursorChatAssistantBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- CheckBox: FluentTheme default foreground doesn't respond to TahoeTextBrush, so checkbox
         labels disappear in dark mode. Override foreground (and Watermark-style placeholder text)
         here so every CheckBox in the app stays readable across light/dark. -->
    <Style Selector="CheckBox">
      <Setter Property="FontFamily" Value="SF Pro Text, .SF NS Text, Segoe UI, Arial" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource TahoeTextBrush}" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="8,4,4,4" />
    </Style>
    <Style Selector="CheckBox /template/ ContentPresenter">
      <Setter Property="TextElement.Foreground" Value="{DynamicResource TahoeTextBrush}" />
    </Style>
    <Style Selector="CheckBox:disabled">
      <Setter Property="Foreground" Value="{DynamicResource TahoeMutedTextBrush}" />
      <Setter Property="Opacity" Value="0.6" />
    </Style>

    <Style Selector="ToggleSwitch">
      <Setter Property="FontFamily" Value="SF Pro Text, .SF NS Text, Segoe UI, Arial" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource TahoeTextBrush}" />
    </Style>

    <!-- TextBox watermark/placeholder: FluentTheme renders it at low opacity of the TextBox
         foreground, which is dark text in dark mode (so the placeholder ends up dark-on-dark).
         Force it to use the muted brush, which has dark + light variants. -->
    <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="Opacity" Value="0.6" />
    </Style>

    <!-- RadioButton parity with CheckBox -->
    <Style Selector="RadioButton">
      <Setter Property="FontFamily" Value="SF Pro Text, .SF NS Text, Segoe UI, Arial" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource TahoeTextBrush}" />
    </Style>
    <Style Selector="RadioButton /template/ ContentPresenter">
      <Setter Property="TextElement.Foreground" Value="{DynamicResource TahoeTextBrush}" />
    </Style>

    <Style Selector="MenuItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource TahoeButtonHoverBrush}" />
    </Style>

    <Style Selector="Border.tahoe-panel">
      <Setter Property="Background" Value="#181818" />
      <Setter Property="BorderBrush" Value="{DynamicResource CursorFrameBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
    </Style>

    <!-- Jobomate additive classes (accent/ghost/nav/card/section/pill/bubble/…) layered on top of
         the MAOS Tahoe base. No base element styles here — those stay pure MAOS. -->
    <StyleInclude Source="avares://Jobomate/Resources/Theme.axaml" />
  </Application.Styles>

  <Application.Resources>
    <SplineEasing x:Key="MaosEase" X1="0.4" Y1="0" X2="0.2" Y2="1" />

    <Color x:Key="TahoeTextColor">#FAFAFA</Color>
    <Color x:Key="TahoeMutedTextColor">#A1A1AA</Color>
    <Color x:Key="TahoeAccentColor">#007AFF</Color>
    <Color x:Key="LogoRedColor">#E11D29</Color>
    <Color x:Key="LogoBlueColor">#2A6CFF</Color>
    <Color x:Key="LogoYellowColor">#F2BE1A</Color>
    <Color x:Key="LogoGreenColor">#1FC95A</Color>

    <SolidColorBrush x:Key="TahoeTextBrush" Color="{StaticResource TahoeTextColor}" />
    <SolidColorBrush x:Key="TahoeMutedTextBrush" Color="{StaticResource TahoeMutedTextColor}" />
    <SolidColorBrush x:Key="TahoeAccentBrush" Color="{StaticResource TahoeAccentColor}" />
    <SolidColorBrush x:Key="LogoRedBrush" Color="{StaticResource LogoRedColor}" />
    <SolidColorBrush x:Key="LogoBlueBrush" Color="{StaticResource LogoBlueColor}" />
    <SolidColorBrush x:Key="LogoYellowBrush" Color="{StaticResource LogoYellowColor}" />
    <SolidColorBrush x:Key="LogoGreenBrush" Color="{StaticResource LogoGreenColor}" />
    <SolidColorBrush x:Key="IconBlackBrush" Color="#FAFAFA" />
    <SolidColorBrush x:Key="CmdPurpleBrush" Color="#5E35B1" />

    <!-- Job* aliases: keep existing/reused views resolving while the shell is rebuilt onto MAOS. -->
    <SplineEasing x:Key="JobEase" X1="0.4" Y1="0" X2="0.2" Y2="1" />
    <SolidColorBrush x:Key="JobBgBrush" Color="#000000" />
    <SolidColorBrush x:Key="JobBgRaisedBrush" Color="#0C0C0C" />
    <SolidColorBrush x:Key="JobBgGradientBrush" Color="#000000" />
    <SolidColorBrush x:Key="JobPanelBrush" Color="#181818" />
    <SolidColorBrush x:Key="JobPanelRaisedBrush" Color="#1F1F1F" />
    <SolidColorBrush x:Key="JobInputBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="JobChatInputBrush" Color="#303030" />
    <SolidColorBrush x:Key="JobBorderBrush" Color="#262626" />
    <SolidColorBrush x:Key="JobBorderSoftBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="JobAccentBrush" Color="#007AFF" />
    <SolidColorBrush x:Key="JobAccentSoftBrush" Color="#11243B" />
    <SolidColorBrush x:Key="JobAccentGreenBrush" Color="#1FC95A" />
    <SolidColorBrush x:Key="JobWarnBrush" Color="#F2BE1A" />
    <SolidColorBrush x:Key="JobDangerBrush" Color="#E11D29" />
    <SolidColorBrush x:Key="JobTextBrush" Color="#FAFAFA" />
    <SolidColorBrush x:Key="JobMutedBrush" Color="#A1A1AA" />

    <!-- Force the system accent to Tahoe blue so FluentTheme accent buttons aren't macOS orange. -->
    <Color x:Key="SystemAccentColor">#007AFF</Color>
    <Color x:Key="SystemAccentColorDark1">#006FE6</Color>
    <Color x:Key="SystemAccentColorDark2">#0060C9</Color>
    <Color x:Key="SystemAccentColorDark3">#0052AB</Color>
    <Color x:Key="SystemAccentColorLight1">#2E90FF</Color>
    <Color x:Key="SystemAccentColorLight2">#5AA8FF</Color>
    <Color x:Key="SystemAccentColorLight3">#85C0FF</Color>
    <SolidColorBrush x:Key="AccentButtonBackground" Color="#007AFF" />
    <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#2E90FF" />
    <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#0060C9" />
    <SolidColorBrush x:Key="AccentButtonForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="#FFFFFF" />
    <!-- Seamless UI: all resting border brushes are transparent (separation comes from fills). -->
    <SolidColorBrush x:Key="TahoeGlassBorderBrush" Color="#00000000" />
    <SolidColorBrush x:Key="TahoeGlassHairlineBrush" Color="#00000000" />
    <SolidColorBrush x:Key="TahoeControlBorderBrush" Color="#00000000" />
    <SolidColorBrush x:Key="TahoeInputBrush" Color="#000000" />
    <SolidColorBrush x:Key="TahoeButtonBorderBrush" Color="#00000000" />
    <SolidColorBrush x:Key="TahoeBoundaryBrush" Color="#00000000" />

    <SolidColorBrush x:Key="CursorFrameBorderBrush" Color="#00000000" />
    <SolidColorBrush x:Key="CursorControlBorderBrush" Color="#00000000" />
    <SolidColorBrush x:Key="CursorControlBorderHoverBrush" Color="#00000000" />
    <SolidColorBrush x:Key="CursorFocusRingBrush" Color="#007AFF" />
    <SolidColorBrush x:Key="CursorMenuBorderBrush" Color="#00000000" />

    <!-- FluentTheme TextBox: transparent border in every state (kills the system-accent focus
         ring) + one flat input background, so inputs are seamless with the surface. -->
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#00000000" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#00000000" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#00000000" />
    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="#00000000" />
    <SolidColorBrush x:Key="TextControlBackground" Color="#000000" />
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#000000" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#000000" />
    <SolidColorBrush x:Key="CursorChatUserBorderBrush" Color="#00000000" />
    <SolidColorBrush x:Key="CursorChatAssistantBorderBrush" Color="#00000000" />

    <!-- Uniform pure-black ("Vantablack") surfaces — no grey panels anywhere. -->
    <SolidColorBrush x:Key="TahoePanelBrush" Color="#000000" />
    <SolidColorBrush x:Key="TahoeWindowBrush" Color="#000000" />
    <SolidColorBrush x:Key="TahoeGlassBrush" Color="#000000" />
    <SolidColorBrush x:Key="TahoeMeshBrush" Color="#000000" />
    <SolidColorBrush x:Key="TahoeMicroTextureBrush" Color="#000000" />
    <SolidColorBrush x:Key="TahoeSurfaceBrush" Color="#000000" />
    <SolidColorBrush x:Key="TahoeToolbarBrush" Color="#000000" />
    <SolidColorBrush x:Key="TahoeButtonBrush" Color="#000000" />
    <SolidColorBrush x:Key="TahoeButtonHoverBrush" Color="#000000" />
    <SolidColorBrush x:Key="TahoeButtonPressedBrush" Color="#000000" />
    <SolidColorBrush x:Key="TahoePillBrush" Color="#000000" />
    <SolidColorBrush x:Key="TahoeIconButtonBrush" Color="#000000" />
    <SolidColorBrush x:Key="TahoeCardBrush" Color="#000000" />
    <SolidColorBrush x:Key="TahoeCardHoverBrush" Color="#000000" />

