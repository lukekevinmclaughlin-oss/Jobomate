<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Jobomate.App"
             Name="Jobomate"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Jobomate/Resources/Theme.axaml" />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <SplineEasing x:Key="JobEase" X1="0.4" Y1="0" X2="0.2" Y2="1" />

            <!-- Primitive tokens — MultiAgentOS "Tahoe" dark scheme (Vantablack + #007AFF) -->
            <Color x:Key="JobBgColor">#000000</Color>
            <Color x:Key="JobBgRaisedColor">#0C0C0C</Color>
            <Color x:Key="JobPanelColor">#181818</Color>
            <Color x:Key="JobPanelRaisedColor">#1F1F1F</Color>
            <Color x:Key="JobInputColor">#1A1A1A</Color>
            <Color x:Key="JobChatInputColor">#303030</Color>
            <Color x:Key="JobBorderColor">#262626</Color>
            <Color x:Key="JobBorderSoftColor">#1A1A1A</Color>
            <Color x:Key="JobAccentColor">#007AFF</Color>
            <Color x:Key="JobAccentSoftColor">#11243B</Color>
            <Color x:Key="JobAccentGreenColor">#1FC95A</Color>
            <Color x:Key="JobWarnColor">#F2BE1A</Color>
            <Color x:Key="JobDangerColor">#E11D29</Color>
            <Color x:Key="JobTextColor">#FAFAFA</Color>
            <Color x:Key="JobMutedColor">#A1A1AA</Color>

            <!-- Logo accent colors (the multicolored cogs) -->
            <Color x:Key="LogoRedColor">#E11D29</Color>
            <Color x:Key="LogoBlueColor">#2A6CFF</Color>
            <Color x:Key="LogoYellowColor">#F2BE1A</Color>
            <Color x:Key="LogoGreenColor">#1FC95A</Color>

            <!-- Semantic brushes -->
            <SolidColorBrush x:Key="JobBgBrush" Color="{StaticResource JobBgColor}" />
            <SolidColorBrush x:Key="JobBgRaisedBrush" Color="{StaticResource JobBgRaisedColor}" />
            <SolidColorBrush x:Key="JobBgGradientBrush" Color="{StaticResource JobBgColor}" />
            <SolidColorBrush x:Key="JobPanelBrush" Color="{StaticResource JobPanelColor}" />
            <SolidColorBrush x:Key="JobPanelRaisedBrush" Color="{StaticResource JobPanelRaisedColor}" />
            <SolidColorBrush x:Key="JobInputBrush" Color="{StaticResource JobInputColor}" />
            <SolidColorBrush x:Key="JobChatInputBrush" Color="{StaticResource JobChatInputColor}" />
            <SolidColorBrush x:Key="JobBorderBrush" Color="{StaticResource JobBorderColor}" />
            <SolidColorBrush x:Key="JobBorderSoftBrush" Color="{StaticResource JobBorderSoftColor}" />
            <SolidColorBrush x:Key="JobAccentBrush" Color="{StaticResource JobAccentColor}" />
            <SolidColorBrush x:Key="JobAccentSoftBrush" Color="{StaticResource JobAccentSoftColor}" />
            <SolidColorBrush x:Key="JobAccentGreenBrush" Color="{StaticResource JobAccentGreenColor}" />
            <SolidColorBrush x:Key="JobWarnBrush" Color="{StaticResource JobWarnColor}" />
            <SolidColorBrush x:Key="JobDangerBrush" Color="{StaticResource JobDangerColor}" />
            <SolidColorBrush x:Key="JobTextBrush" Color="{StaticResource JobTextColor}" />
            <SolidColorBrush x:Key="JobMutedBrush" Color="{StaticResource JobMutedColor}" />
            <SolidColorBrush x:Key="LogoRedBrush" Color="{StaticResource LogoRedColor}" />
            <SolidColorBrush x:Key="LogoBlueBrush" Color="{StaticResource LogoBlueColor}" />
            <SolidColorBrush x:Key="LogoYellowBrush" Color="{StaticResource LogoYellowColor}" />
            <SolidColorBrush x:Key="LogoGreenBrush" Color="{StaticResource LogoGreenColor}" />

            <!-- Accent (Fluent + built-in accent buttons) → #007AFF -->
            <Color x:Key="SystemAccentColor">#007AFF</Color>
            <Color x:Key="SystemAccentColorDark1">#006FE6</Color>
            <Color x:Key="SystemAccentColorDark2">#0060C9</Color>
            <Color x:Key="SystemAccentColorDark3">#0052AB</Color>
            <Color x:Key="SystemAccentColorLight1">#2E90FF</Color>
            <Color x:Key="SystemAccentColorLight2">#5AA8FF</Color>
            <Color x:Key="SystemAccentColorLight3">#85C0FF</Color>
            <SolidColorBrush x:Key="AccentButtonBackground" Color="#007AFF" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#2E90FF" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#0060C9" />
            <SolidColorBrush x:Key="AccentButtonForeground" Color="#FFFFFF" />
            <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="#FFFFFF" />
            <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="#FFFFFF" />

            <!-- Text inputs / combo boxes: dark + seamless, #007AFF focus -->
            <SolidColorBrush x:Key="TextControlBackground" Color="{StaticResource JobInputColor}" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{StaticResource JobInputColor}" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{StaticResource JobInputColor}" />
            <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="{StaticResource JobBgColor}" />
            <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource JobBorderColor}" />
            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#3A3A3A" />
            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{StaticResource JobAccentColor}" />
            <SolidColorBrush x:Key="TextControlForeground" Color="{StaticResource JobTextColor}" />
            <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{StaticResource JobTextColor}" />
            <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{StaticResource JobTextColor}" />
            <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="{StaticResource JobMutedColor}" />
            <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="{StaticResource JobMutedColor}" />
            <SolidColorBrush x:Key="ComboBoxBackground" Color="{StaticResource JobInputColor}" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="{StaticResource JobPanelRaisedColor}" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="{StaticResource JobPanelRaisedColor}" />
            <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{StaticResource JobPanelColor}" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="{StaticResource JobAccentSoftColor}" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="{StaticResource JobAccentSoftColor}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
