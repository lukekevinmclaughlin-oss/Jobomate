<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Additive classes only — layered on top of the MAOS Tahoe base in App.axaml. No base element
         styles here (Window/TextBlock/TextBox/Button/ComboBox stay pure MAOS). -->

    <Style Selector="TextBlock.title">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TahoeTextBrush}" />
    </Style>
    <Style Selector="TextBlock.caption">
        <Setter Property="Foreground" Value="{DynamicResource TahoeMutedTextBrush}" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Primary action — solid Tahoe blue -->
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="#007AFF" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14,9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#2E90FF" />
    </Style>
    <Style Selector="Button.accent:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#0060C9" />
    </Style>

    <!-- Secondary -->
    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="#1F1F1F" />
        <Setter Property="Foreground" Value="{DynamicResource TahoeTextBrush}" />
        <Setter Property="BorderBrush" Value="#262626" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="13,8" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#2A2A2A" />
    </Style>

    <Style Selector="Button.subtle">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TahoeMutedTextBrush}" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.subtle:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#1F1F1F" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource TahoeTextBrush}" />
    </Style>

    <!-- Sidebar nav (legacy ShellView; harmless if unused) -->
    <Style Selector="Button.nav">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TahoeMutedTextBrush}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.nav.active">
        <Setter Property="Foreground" Value="{DynamicResource TahoeTextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.nav.active /template/ ContentPresenter">
        <Setter Property="Background" Value="#11243B" />
    </Style>

    <!-- Cards / sections -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="#181818" />
        <Setter Property="BorderBrush" Value="#1A1A1A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="Border.section">
        <Setter Property="Background" Value="#181818" />
        <Setter Property="BorderBrush" Value="#1A1A1A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="Border.pill">
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Background" Value="#1F1F1F" />
    </Style>

    <!-- Conversation bubbles (legacy CommandCenterView; harmless if unused) -->
    <Style Selector="Border.bubble">
        <Setter Property="Background" Value="#181818" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="MaxWidth" Value="640" />
    </Style>
    <Style Selector="Border.bubble-user">
        <Setter Property="Background" Value="#11243B" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="MaxWidth" Value="640" />
    </Style>
    <Style Selector="Border.logo-badge">
        <Setter Property="Background" Value="White" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="6" />
    </Style>
</Styles>
