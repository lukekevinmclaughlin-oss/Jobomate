<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Jobomate.Views.AssistantView">
  <Grid RowDefinitions="*,Auto,Auto">

    <!-- Transcript + bento empty state -->
    <Grid Grid.Row="0">
      <ScrollViewer x:Name="Scroller" VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="Conversation" Margin="8,10,8,10" Spacing="12" MaxWidth="900" HorizontalAlignment="Stretch" />
      </ScrollViewer>

      <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14" Width="252">
        <Border Background="White" CornerRadius="18" Width="76" Height="76" Padding="8" HorizontalAlignment="Center">
          <Image Source="avares://Jobomate/Resources/JobomateLogo.png" Stretch="Uniform" />
        </Border>
        <TextBlock Text="What would you like to do?" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TahoeTextBrush}" HorizontalAlignment="Center" />

        <Button Classes="codex-card" Click="BentoRecent_Click" ToolTip.Tip="Search reputable sources for fresh openings">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <Path Width="24" Height="24" Stretch="Uniform" Fill="#94A3B8" Data="{DynamicResource IconBell}" />
            <TextBlock Text="① Recent job postings" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center" />
            <TextBlock Text="Find &amp; rank fresh openings, then draft" FontSize="12.5" Foreground="#A7B4C7" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
          </StackPanel>
        </Button>

        <Button Classes="codex-card" Click="BentoUnsolicited_Click" ToolTip.Tip="Research target employers for speculative applications">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <Path Width="24" Height="24" Stretch="Uniform" Fill="#94A3B8" Data="{DynamicResource IconTarget}" />
            <TextBlock Text="② Unsolicited applications" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center" />
            <TextBlock Text="Research employers &amp; official contacts" FontSize="12.5" Foreground="#A7B4C7" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
          </StackPanel>
        </Button>

        <Button Classes="codex-card" Click="BentoBrowser_Click" ToolTip.Tip="Open the built-in WebKit browser; you log in, the assistant takes over to collect jobs">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <Path Width="24" Height="24" Stretch="Uniform" Fill="#94A3B8" Data="{DynamicResource IconGlobe}" />
            <TextBlock Text="LLM Browser" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" HorizontalAlignment="Center" />
            <TextBlock Text="Open a real WebKit browser — you log in, the assistant takes over" FontSize="12.5" Foreground="#A7B4C7" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
          </StackPanel>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Status strip -->
    <Border Grid.Row="1" Classes="cursor-frame" Margin="0,8,0,8" Padding="11,7" CornerRadius="8" Background="#000000"
            BorderBrush="{DynamicResource CursorFrameBorderBrush}" BorderThickness="1">
      <Grid ColumnDefinitions="Auto,18,Auto,18,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
          <Border x:Name="ConnDot" Width="7" Height="7" CornerRadius="4" Background="#9CA3AF" VerticalAlignment="Center" />
          <TextBlock x:Name="ConnText" Text="No model" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource TahoeTextBrush}" VerticalAlignment="Center" />
          <Button x:Name="ConnectButton" Classes="subtle" Content="Connect" FontSize="11" Padding="9,3" MinHeight="0" VerticalAlignment="Center" />
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Border x:Name="RunDot" Width="7" Height="7" CornerRadius="4" Background="#3A3A3A" VerticalAlignment="Center" />
          <TextBlock x:Name="RunText" Text="Idle" FontSize="12.5" Foreground="{DynamicResource TahoeMutedTextBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="320" />
        </StackPanel>
        <TextBlock Grid.Column="4" x:Name="StatusDryRun" Text="Dry-run · nothing sends without approval" FontSize="12.5"
                   Foreground="{DynamicResource TahoeMutedTextBrush}" VerticalAlignment="Center" Margin="0,0,12,0" TextTrimming="CharacterEllipsis" />
        <TextBlock Grid.Column="5" x:Name="TokensText" Text="0 tok" FontSize="12.5" Foreground="{DynamicResource TahoeMutedTextBrush}" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- Composer dock -->
    <StackPanel Grid.Row="2" Spacing="8">
      <WrapPanel x:Name="QuickActions" />
      <TextBox x:Name="InputBox" Classes="cursor-prompt-input" AcceptsReturn="True" TextWrapping="Wrap"
               MinHeight="64" MaxHeight="180" FontSize="14.5"
               Watermark="Message Jobomate — or use the buttons above" />
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" Text="Enter to send · Shift+Enter for a new line" FontSize="11.5"
                   Foreground="{DynamicResource TahoeMutedTextBrush}" VerticalAlignment="Center" Margin="2,0,0,0" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
          <Button x:Name="AttachButton" Classes="tahoe-icon" ToolTip.Tip="Attach / load a CV">
            <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource TahoeMutedTextBrush}" Data="{DynamicResource IconFolder}" />
          </Button>
          <Button x:Name="ModelButton" Classes="tahoe-icon" ToolTip.Tip="Model &amp; connection">
            <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource LogoBlueBrush}" Data="{DynamicResource IconBolt}" />
          </Button>
          <Button x:Name="SettingsButton" Classes="tahoe-icon" ToolTip.Tip="Settings">
            <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource TahoeMutedTextBrush}" Data="{DynamicResource IconCog}" />
          </Button>
          <Button x:Name="SendButton" Classes="tahoe-icon" ToolTip.Tip="Send">
            <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource TahoeTextBrush}" Data="{DynamicResource IconArrowUp}" />
          </Button>
        </StackPanel>
      </Grid>
    </StackPanel>
  </Grid>
</UserControl>
