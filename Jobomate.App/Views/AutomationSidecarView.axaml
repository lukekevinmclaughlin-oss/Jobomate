<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Jobomate.Views.AutomationSidecarView">
    <Grid RowDefinitions="Auto,Auto,Auto,*" Background="{DynamicResource JobPanelBrush}">
        <StackPanel Grid.Row="0" Margin="14,12,14,4" Spacing="2">
            <TextBlock Text="NOW" Classes="muted" FontSize="10" />
            <TextBlock x:Name="NowText" Foreground="{DynamicResource JobTextBrush}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Text="Ready" />
            <TextBlock x:Name="CountsText" Classes="muted" FontSize="11.5" TextWrapping="Wrap" Text="—" Margin="0,4,0,0" />
            <TextBlock x:Name="CostText" Classes="muted" FontSize="11" Text="" />
        </StackPanel>

        <Border Grid.Row="1" Margin="14,4" Padding="10" Background="{DynamicResource JobBgBrush}" CornerRadius="8"
                BorderBrush="{DynamicResource JobBorderBrush}" BorderThickness="1">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border x:Name="LlmDot" Width="9" Height="9" CornerRadius="5" Background="#3A3A3A" VerticalAlignment="Center" />
                    <TextBlock Text="LLM" Classes="muted" FontSize="10" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock x:Name="LlmText" Text="idle" Foreground="{DynamicResource JobTextBrush}" FontSize="11.5" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Margin="14,0,14,4" Padding="10" Background="{DynamicResource JobBgBrush}" CornerRadius="8"
                BorderBrush="{DynamicResource JobBorderBrush}" BorderThickness="1">
            <StackPanel Spacing="2">
                <TextBlock Text="BROWSER EXTENSION" Classes="muted" FontSize="10" />
                <TextBlock x:Name="ExtText" Foreground="{DynamicResource JobTextBrush}" FontSize="11.5" TextWrapping="Wrap" Text="Not connected" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" RowDefinitions="Auto,*" Margin="14,4,8,12">
            <TextBlock Grid.Row="0" Text="RECENT ACTIVITY" Classes="muted" FontSize="10" Margin="0,0,0,6" />
            <ScrollViewer Grid.Row="1">
                <ItemsControl x:Name="ActivityList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Classes="muted" FontSize="10.5" FontFamily="Menlo, monospace" TextWrapping="Wrap" Margin="0,2" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
