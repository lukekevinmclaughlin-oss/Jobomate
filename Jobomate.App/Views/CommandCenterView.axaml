<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Jobomate.Views.CommandCenterView">
    <Grid RowDefinitions="*,Auto" Background="{DynamicResource JobBgBrush}">
        <ScrollViewer Grid.Row="0" x:Name="Scroller" Padding="26,20">
            <StackPanel x:Name="Conversation" Spacing="12" MaxWidth="940" HorizontalAlignment="Stretch" />
        </ScrollViewer>

        <Border Grid.Row="1" Background="{DynamicResource JobPanelBrush}"
                BorderBrush="{DynamicResource JobBorderBrush}" BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel Spacing="10">
                <WrapPanel x:Name="QuickActions" />
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" x:Name="InputBox" Watermark="Type a reply, or use the buttons above…" />
                    <Button Grid.Column="1" x:Name="SendButton" Classes="accent" Content="Send" Margin="8,0,0,0" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
