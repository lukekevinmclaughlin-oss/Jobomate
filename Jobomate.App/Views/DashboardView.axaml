<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Jobomate.Views.DashboardView">

    <TabControl Padding="0" Margin="8,4,8,8">

        <!-- ============ PROFILE ============ -->
        <TabItem Header="Candidate">
            <ScrollViewer Padding="20">
                <StackPanel Spacing="12" MaxWidth="760" HorizontalAlignment="Left">
                    <TextBlock Text="Candidate profile" Classes="heading" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="LoadCvButton" Classes="ghost" Content="Load a different CV…" />
                        <Button x:Name="SaveProfileButton" Classes="accent" Content="Save profile" />
                        <TextBlock x:Name="ProfileStatus" Classes="muted" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="Full name" Classes="muted" />
                    <TextBox x:Name="PName" />
                    <TextBlock Text="Headline" Classes="muted" />
                    <TextBox x:Name="PHeadline" />
                    <TextBlock Text="Location" Classes="muted" />
                    <TextBox x:Name="PLocation" />
                    <TextBlock Text="Contact email" Classes="muted" />
                    <TextBox x:Name="PEmail" />
                    <TextBlock Text="Summary" Classes="muted" />
                    <TextBox x:Name="PSummary" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" />
                    <Border Classes="card">
                        <TextBlock x:Name="PFacts" TextWrapping="Wrap" Classes="muted" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- ============ SEARCH ============ -->
        <TabItem Header="Search &amp; Results">
            <Grid ColumnDefinitions="360,*" Margin="0">
                <!-- Filters -->
                <ScrollViewer Grid.Column="0" Padding="18" Background="{DynamicResource JobPanelBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Search mode" Classes="heading" />
                        <RadioButton x:Name="ModeRecent" GroupName="dmode" Content="Recent job postings" IsChecked="True" />
                        <RadioButton x:Name="ModeUnsolicited" GroupName="dmode" Content="Unsolicited applications" />

                        <TextBlock Text="Keywords" Classes="muted" Margin="0,8,0,0" />
                        <TextBox x:Name="KeywordsBox" Text="growth marketing biotech" />

                        <TextBlock Text="Location" Classes="muted" />
                        <ComboBox x:Name="LocationCombo" HorizontalAlignment="Stretch" />
                        <TextBox x:Name="CustomLocationBox" Watermark="Custom location (optional)" />

                        <TextBlock Text="Language match mode" Classes="muted" Margin="0,8,0,0" />
                        <ComboBox x:Name="LangModeCombo" HorizontalAlignment="Stretch" />

                        <TextBlock Text="Accepted required languages" Classes="muted" />
                        <Border Classes="card" Padding="8">
                            <WrapPanel x:Name="LanguagePanel" />
                        </Border>

                        <TextBlock Text="Work location" Classes="muted" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <CheckBox x:Name="WlRemote" Content="Remote" />
                            <CheckBox x:Name="WlHybrid" Content="Hybrid" />
                            <CheckBox x:Name="WlOnsite" Content="On-site" />
                        </StackPanel>
                        <CheckBox x:Name="IncludeUnclearWork" Content="Include unclear work-location" IsChecked="True" />
                        <CheckBox x:Name="ExcludeStartRisk" Content="Exclude start-date risks" />

                        <Button x:Name="RunSearchButton" Classes="accent" Content="Run search" HorizontalAlignment="Stretch" Margin="0,10,0,0" />
                        <TextBlock x:Name="SearchStatus" Classes="muted" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>

                <!-- Results -->
                <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" Margin="14,12">
                    <TextBlock Grid.Row="0" x:Name="ResultsHeader" Text="Results" Classes="heading" />
                    <ListBox Grid.Row="1" x:Name="ResultsList" SelectionMode="Multiple" Margin="0,8" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2" Margin="2,6">
                                    <TextBlock Text="{Binding Header}" FontWeight="SemiBold" Foreground="{DynamicResource JobTextBrush}" />
                                    <TextBlock Text="{Binding Sub}" Classes="muted" />
                                    <TextBlock Text="{Binding Decision}" FontSize="12" Foreground="{DynamicResource JobAccentGreenBrush}" />
                                    <TextBlock Text="{Binding LanguageSummary}" Classes="muted" FontSize="11.5" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Method}" Classes="muted" FontSize="11.5" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10">
                        <Button x:Name="GenerateDraftsButton" Classes="accent" Content="Generate drafts for selected" />
                        <TextBlock x:Name="GenerateStatus" Classes="muted" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Grid>
        </TabItem>

        <!-- ============ DRAFTS & APPROVAL ============ -->
        <TabItem Header="Drafts &amp; Approval">
            <Grid ColumnDefinitions="360,*" Margin="0">
                <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto" Background="{DynamicResource JobPanelBrush}" >
                    <TextBlock Grid.Row="0" Text="Drafts (approval wall)" Classes="heading" Margin="16,14,16,4" />
                    <ListBox Grid.Row="1" x:Name="DraftsList" Margin="8" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2" Margin="2,5">
                                    <TextBlock Text="{Binding Header}" FontWeight="SemiBold" Foreground="{DynamicResource JobTextBrush}" />
                                    <TextBlock Text="{Binding Subject}" Classes="muted" FontSize="11.5" />
                                    <TextBlock Text="{Binding Status}" FontSize="11.5" Foreground="{DynamicResource JobAccentBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="2" Spacing="8" Margin="12">
                        <Button x:Name="ApproveAllButton" Classes="ghost" Content="Approve all visible" HorizontalAlignment="Stretch" />
                        <Button x:Name="ScheduleApprovedButton" Classes="accent" Content="Schedule approved (spaced sending)" HorizontalAlignment="Stretch" />
                        <TextBlock x:Name="ApprovalStatus" Classes="muted" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Column="1" Padding="18">
                    <StackPanel Spacing="8" x:Name="DraftDetail" IsVisible="False">
                        <TextBlock x:Name="DetailHeader" Classes="heading" />
                        <TextBlock Text="To" Classes="muted" />
                        <TextBox x:Name="DetailTo" />
                        <TextBlock Text="Subject" Classes="muted" />
                        <TextBox x:Name="DetailSubject" />
                        <TextBlock Text="Email body" Classes="muted" />
                        <TextBox x:Name="DetailBody" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="160" />
                        <TextBlock Text="Cover letter" Classes="muted" />
                        <TextBox x:Name="DetailCover" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="160" />
                        <TextBlock x:Name="DetailAttachments" Classes="muted" TextWrapping="Wrap" />
                        <WrapPanel>
                            <Button x:Name="ApproveButton" Classes="accent" Content="Approve" Margin="0,0,8,8" />
                            <Button x:Name="RejectButton" Classes="ghost" Content="Reject" Margin="0,0,8,8" />
                            <Button x:Name="SaveEditButton" Classes="ghost" Content="Save edits" Margin="0,0,8,8" />
                            <Button x:Name="RegenerateButton" Classes="ghost" Content="Regenerate" Margin="0,0,8,8" />
                            <Button x:Name="PauseButton" Classes="ghost" Content="Pause" Margin="0,0,8,8" />
                            <Button x:Name="ExportPdfButton" Classes="ghost" Content="Export cover letter PDF" Margin="0,0,8,8" />
                        </WrapPanel>
                        <TextBlock x:Name="DetailStatus" Classes="muted" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </TabItem>

        <!-- ============ QUEUE & TRACKER ============ -->
        <TabItem Header="Queue &amp; Tracker">
            <Grid ColumnDefinitions="*,*" Margin="16">
                <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,10,0">
                    <TextBlock Text="Approved queue / outbox" Classes="heading" />
                    <WrapPanel>
                        <Button x:Name="SendDueButton" Classes="accent" Content="Send due now" Margin="0,0,8,8" />
                        <Button x:Name="PauseQueueButton" Classes="ghost" Content="Pause" Margin="0,0,8,8" />
                        <Button x:Name="ResumeQueueButton" Classes="ghost" Content="Resume" Margin="0,0,8,8" />
                        <Button x:Name="CancelQueueButton" Classes="ghost" Content="Cancel" Margin="0,0,8,8" />
                    </WrapPanel>
                    <TextBlock x:Name="QueueStatus" Classes="muted" TextWrapping="Wrap" />
                    <ListBox x:Name="QueueList" Height="420" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2" Margin="2,5">
                                    <TextBlock Text="{Binding Header}" FontWeight="SemiBold" Foreground="{DynamicResource JobTextBrush}" />
                                    <TextBlock Text="{Binding When}" Classes="muted" FontSize="11.5" />
                                    <TextBlock Text="{Binding Status}" FontSize="11.5" Foreground="{DynamicResource JobAccentBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="8" Margin="10,0,0,0">
                    <TextBlock Text="Application tracker" Classes="heading" />
                    <Button x:Name="RefreshTrackerButton" Classes="ghost" Content="Refresh" HorizontalAlignment="Left" />
                    <ListBox x:Name="TrackerList" Height="460" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2" Margin="2,5">
                                    <TextBlock Text="{Binding Header}" FontWeight="SemiBold" Foreground="{DynamicResource JobTextBrush}" />
                                    <TextBlock Text="{Binding Status}" Classes="muted" FontSize="11.5" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
        </TabItem>

        <!-- ============ SETTINGS ============ -->
        <TabItem Header="Settings">
            <ScrollViewer Padding="20">
                <StackPanel Spacing="12" MaxWidth="780" HorizontalAlignment="Left">
                    <TextBlock Text="LLM connection" Classes="heading" />
                    <StackPanel Spacing="6">
                        <RadioButton x:Name="SLlmCloud" GroupName="sllm" Content="Cloud API" IsChecked="True" />
                        <RadioButton x:Name="SLlmLocal" GroupName="sllm" Content="Local server (Ollama / LM Studio / custom)" />
                        <RadioButton x:Name="SLlmGguf" GroupName="sllm" Content="Local GGUF file" />
                    </StackPanel>
                    <StackPanel x:Name="SCloudPanel" Spacing="8">
                        <ComboBox x:Name="SProviderCombo" HorizontalAlignment="Stretch" />
                        <TextBox x:Name="SModelBox" Watermark="Model (optional)" />
                        <TextBox x:Name="SApiKeyBox" PasswordChar="•" Watermark="API key (stored in Keychain)" />
                    </StackPanel>
                    <StackPanel x:Name="SLocalPanel" Spacing="8" IsVisible="False">
                        <Button x:Name="SDetectButton" Classes="ghost" Content="Auto-detect" HorizontalAlignment="Left" />
                        <TextBox x:Name="SLocalUrlBox" />
                        <TextBox x:Name="SLocalModelBox" Watermark="Model" />
                    </StackPanel>
                    <StackPanel x:Name="SGgufPanel" Spacing="8" IsVisible="False">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="SBrowseGgufButton" Classes="ghost" Content="Choose .gguf…" />
                            <TextBlock x:Name="SGgufLabel" Classes="muted" VerticalAlignment="Center" Text="No model selected" />
                        </StackPanel>
                        <TextBox x:Name="SContextBox" Text="4096" Width="120" HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="SSaveLlmButton" Classes="accent" Content="Save &amp; test" />
                        <TextBlock x:Name="SLlmStatus" Classes="muted" VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource JobBorderBrush}" Margin="0,8" />

                    <TextBlock Text="Email account" Classes="heading" />
                    <StackPanel Spacing="6">
                        <RadioButton x:Name="SEmailDry" GroupName="semail" Content="Dry run (never sends)" IsChecked="True" />
                        <RadioButton x:Name="SEmailSmtp" GroupName="semail" Content="SMTP" />
                        <RadioButton x:Name="SEmailGmail" GroupName="semail" Content="Gmail (OAuth)" />
                        <RadioButton x:Name="SEmailMs" GroupName="semail" Content="Microsoft 365 (Graph)" />
                    </StackPanel>
                    <StackPanel x:Name="SSmtpPanel" Spacing="8" IsVisible="False">
                        <TextBox x:Name="SFromBox" Watermark="From address" />
                        <TextBox x:Name="SFromNameBox" Watermark="From name" />
                        <TextBox x:Name="SHostBox" Watermark="smtp host" />
                        <TextBox x:Name="SPortBox" Text="587" Width="100" HorizontalAlignment="Left" />
                        <TextBox x:Name="SUserBox" Watermark="username" />
                        <TextBox x:Name="SPassBox" PasswordChar="•" Watermark="password / app password" />
                    </StackPanel>
                    <StackPanel x:Name="SOAuthPanel" Spacing="8" IsVisible="False">
                        <TextBox x:Name="SOAuthFromBox" Watermark="From address" />
                        <TextBox x:Name="SOAuthClientBox" Watermark="OAuth client id" />
                        <Button x:Name="SOAuthSignInButton" Classes="ghost" Content="Sign in" HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="SSaveEmailButton" Classes="accent" Content="Save &amp; test" />
                        <TextBlock x:Name="SEmailStatus" Classes="muted" VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Classes="card" Margin="0,8,0,0">
                        <TextBlock Classes="muted" TextWrapping="Wrap"
                                   Text="Sending limits: max 8 emails/day, ≥25 min apart, +5–15 min jitter, quiet hours 20:00–08:00 Europe/Berlin. The queue stops immediately on auth errors, throttling, bounces, or repeated failures. Secrets live only in the macOS Keychain; logs are redacted." />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- ============ AUDIT ============ -->
        <TabItem Header="Audit">
            <Grid RowDefinitions="Auto,*" Margin="16">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Audit log" Classes="heading" />
                    <Button x:Name="RefreshAuditButton" Classes="ghost" Content="Refresh" />
                </StackPanel>
                <ListBox Grid.Row="1" x:Name="AuditList" Margin="0,8" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Line}" Classes="muted" FontFamily="Menlo, monospace" FontSize="11.5" TextWrapping="Wrap" Margin="2,3" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
