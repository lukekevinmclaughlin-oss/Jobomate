<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="using:Jobomate.Views"
        x:Class="Jobomate.Views.MainWindow"
        Title="Jobomate"
        Width="1280" Height="860" MinWidth="940" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="None"
        Background="#0B0B0B"
        UseLayoutRounding="True"
        RenderOptions.TextRenderingMode="Antialias">

  <Border x:Name="RootChrome" Classes="cursor-frame" CornerRadius="8" Background="#0B0B0B"
          BorderBrush="{DynamicResource CursorFrameBorderBrush}" BorderThickness="1">
    <Grid x:Name="LayoutGrid">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="236" />
        <ColumnDefinition Width="6" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="0" />
        <ColumnDefinition Width="0" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- macOS traffic lights, pinned to the true top-left corner -->
      <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal"
                  HorizontalAlignment="Left" VerticalAlignment="Top"
                  Margin="20,15,0,0" Spacing="8" ZIndex="100">
        <Button Classes="traffic" Background="#FF5F57" BorderBrush="#E0443E" Click="Traffic_Close" ToolTip.Tip="Close" />
        <Button Classes="traffic" Background="#FEBC2E" BorderBrush="#DEA123" Click="Traffic_Minimize" ToolTip.Tip="Minimize" />
        <Button Classes="traffic" Background="#28C840" BorderBrush="#1AA931" Click="Traffic_Zoom" ToolTip.Tip="Zoom" />
      </StackPanel>

      <!-- Left "runs" sidebar -->
      <Border x:Name="RunsSidebar" Grid.Column="0" Grid.RowSpan="2"
              Margin="14,14,0,14" Padding="14,34,14,14" Classes="tahoe-panel">
        <Grid RowDefinitions="Auto,Auto,*,Auto">
          <Button Grid.Row="0" Content="New chat" Classes="tahoe-pill"
                  HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="NewRun_Click" />
          <TextBox Grid.Row="1" x:Name="RunSearchBox" Watermark="Search chats" Margin="0,0,0,10" MinHeight="38" />
          <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="RunItems" Spacing="6" />
          </ScrollViewer>
          <Border Grid.Row="3" Margin="0,10,0,0" Padding="7" CornerRadius="10" Background="#141414">
            <Viewbox Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Width="34" Height="34" CornerRadius="9" Classes="tahoe-icon" Padding="8"
                        Click="OpenSettings_Click" ToolTip.Tip="Settings">
                  <Path Width="17" Height="17" Stretch="Uniform" Fill="{DynamicResource TahoeMutedTextBrush}" Data="{DynamicResource IconCog}" />
                </Button>
                <Button Width="34" Height="34" CornerRadius="9" Background="#F2BE1A" BorderBrush="#9A7A10" BorderThickness="1.5"
                        Click="ArchiveRuns_Click" ToolTip.Tip="Archive all runs">
                  <Path Width="16" Height="16" Stretch="Uniform" Fill="#1A1A1A" Data="{DynamicResource IconFolder}" />
                </Button>
                <Button Width="34" Height="34" CornerRadius="9" Background="#7A0F14" BorderBrush="#4A0A0D" BorderThickness="1.5"
                        Click="ClearData_Click" ToolTip.Tip="Clear all application data (asks first)">
                  <Path Width="16" Height="16" Stretch="Uniform" Fill="#FFFFFF" Data="{DynamicResource IconTrash}" />
                </Button>
              </StackPanel>
            </Viewbox>
          </Border>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" Grid.RowSpan="2" Width="6" Background="#12AEBBCD" ResizeDirection="Columns" />

      <!-- Center title bar (drag the window from here) -->
      <Grid Grid.Column="2" Grid.Row="0" Margin="16,14,16,8" ColumnDefinitions="Auto,*,Auto"
            Background="Transparent" PointerPressed="TitleBar_PointerPressed">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="11" VerticalAlignment="Center">
          <Border Background="White" CornerRadius="9" Width="36" Height="36" Padding="3">
            <Image Source="avares://Jobomate/Resources/JobomateLogo.png" Stretch="Uniform" />
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Jobomate" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TahoeTextBrush}" />
            <TextBlock x:Name="HeaderSubtitle" Text="Application command center" FontSize="11.5" Foreground="{DynamicResource TahoeMutedTextBrush}" />
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <ToggleButton x:Name="SidebarToggle" Classes="tahoe-icon pane-toggle" IsChecked="True"
                        Click="ToggleSidebar_Click" ToolTip.Tip="Show or hide runs">
            <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource TahoeMutedTextBrush}" Data="{DynamicResource IconSidebarLeft}" />
          </ToggleButton>
          <Button Classes="tahoe-icon" Click="OpenSandbox_Click" ToolTip.Tip="Browser sandbox">
            <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource LogoBlueBrush}" Data="{DynamicResource IconGlobe}" />
          </Button>
          <Button Classes="tahoe-icon" Click="OpenSettings_Click" ToolTip.Tip="Settings">
            <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource TahoeMutedTextBrush}" Data="{DynamicResource IconCog}" />
          </Button>
          <ToggleButton x:Name="SidecarToggle" Classes="tahoe-icon pane-toggle" IsChecked="False"
                        Click="ToggleSidecar_Click" ToolTip.Tip="Show or hide sidecar">
            <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource TahoeMutedTextBrush}" Data="{DynamicResource IconSidebarRight}" />
          </ToggleButton>
        </StackPanel>
      </Grid>

      <!-- Center workspace -->
      <v:AssistantView Grid.Column="2" Grid.Row="1" x:Name="Assistant" Margin="14,0,14,12" />

      <!-- Sidecar -->
      <GridSplitter x:Name="SidecarSplitter" Grid.Column="3" Grid.RowSpan="2" Width="6"
                    IsVisible="False" Background="#18AEBBCD" ResizeDirection="Columns" />
      <v:SidecarView Grid.Column="4" Grid.RowSpan="2" x:Name="Sidecar" Margin="0,14,14,14" IsVisible="False" />
    </Grid>
  </Border>
</Window>
