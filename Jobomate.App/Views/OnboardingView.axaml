<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Jobomate.Views.OnboardingView">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Padding="28,22,28,10">
            <StackPanel Spacing="4">
                <TextBlock x:Name="StepTitle" Classes="heading" FontSize="22" />
                <TextBlock x:Name="StepSubtitle" Classes="muted" />
                <TextBlock x:Name="StepCounter" Classes="muted" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="28,6">
            <Panel MaxWidth="720" HorizontalAlignment="Left">

                <!-- Step 0: Load CV -->
                <StackPanel x:Name="Step0" Spacing="14">
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource JobTextBrush}"
                               Text="Load your CV. Jobomate reads it to ground every application in real facts — it never invents experience." />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="UseDefaultCvButton" Classes="accent" Content="Use default CV" />
                        <Button x:Name="BrowseCvButton" Classes="ghost" Content="Browse…" />
                    </StackPanel>
                    <Border Classes="card">
                        <TextBlock x:Name="CvStatus" TextWrapping="Wrap" Classes="muted"
                                   Text="No CV loaded yet. The known background is used as a safe fallback." />
                    </Border>
                </StackPanel>

                <!-- Step 1: Confirm profile -->
                <StackPanel x:Name="Step1" Spacing="10" IsVisible="False">
                    <TextBlock Text="Full name" Classes="muted" />
                    <TextBox x:Name="ProfileName" />
                    <TextBlock Text="Headline" Classes="muted" />
                    <TextBox x:Name="ProfileHeadline" />
                    <TextBlock Text="Location" Classes="muted" />
                    <TextBox x:Name="ProfileLocation" />
                    <TextBlock Text="Contact email" Classes="muted" />
                    <TextBox x:Name="ProfileEmail" Watermark="you@example.com" />
                    <TextBlock Text="Summary" Classes="muted" />
                    <TextBox x:Name="ProfileSummary" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="96" />
                    <Border Classes="card">
                        <TextBlock TextWrapping="Wrap" Classes="muted"
                                   Text="Languages are kept honest: English (native), German (intermediate). German is never described as fluent." />
                    </Border>
                </StackPanel>

                <!-- Step 2: Availability -->
                <StackPanel x:Name="Step2" Spacing="14" IsVisible="False">
                    <Border Classes="card">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Available to start from" Classes="muted" />
                            <TextBlock Text="1 October 2026" FontSize="30" FontWeight="Bold"
                                       Foreground="{DynamicResource JobAccentBrush}" />
                            <TextBlock TextWrapping="Wrap" Classes="muted"
                                       Text="This hard date is enforced everywhere: ranking prefers compatible jobs, every email states it, cover letters never imply earlier availability, and roles needing an earlier fixed start are flagged as a start-date risk." />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Step 3: Connect LLM -->
                <StackPanel x:Name="Step3" Spacing="10" IsVisible="False">
                    <TextBlock TextWrapping="Wrap" Classes="muted"
                               Text="Connect an LLM. It works in the background; you stay in control. You can change this later in Settings." />
                    <StackPanel Spacing="6">
                        <RadioButton x:Name="LlmCloud" GroupName="llm" Content="Cloud API (OpenAI, Anthropic, Google AI, OpenRouter, Mistral, Groq, DeepSeek, Together, xAI)" IsChecked="True" />
                        <RadioButton x:Name="LlmLocalServer" GroupName="llm" Content="Local server (Ollama / LM Studio / custom)" />
                        <RadioButton x:Name="LlmGguf" GroupName="llm" Content="Local GGUF file" />
                        <RadioButton x:Name="LlmSkip" GroupName="llm" Content="Skip for now" />
                    </StackPanel>

                    <StackPanel x:Name="CloudPanel" Spacing="8">
                        <TextBlock Text="Provider" Classes="muted" />
                        <ComboBox x:Name="ProviderCombo" HorizontalAlignment="Stretch" />
                        <TextBlock Text="Model (optional — uses a sensible default)" Classes="muted" />
                        <TextBox x:Name="ModelBox" Watermark="e.g. gpt-4o" />
                        <TextBlock Text="API key (stored in macOS Keychain)" Classes="muted" />
                        <TextBox x:Name="ApiKeyBox" PasswordChar="•" />
                    </StackPanel>

                    <StackPanel x:Name="LocalServerPanel" Spacing="8" IsVisible="False">
                        <Button x:Name="DetectButton" Classes="ghost" Content="Auto-detect local servers" />
                        <TextBlock Text="Server URL" Classes="muted" />
                        <TextBox x:Name="LocalServerUrlBox" Text="http://127.0.0.1:11434/v1/chat/completions" />
                        <TextBlock Text="Model" Classes="muted" />
                        <TextBox x:Name="LocalModelBox" Watermark="e.g. llama3.1" />
                    </StackPanel>

                    <StackPanel x:Name="GgufPanel" Spacing="8" IsVisible="False">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="BrowseGgufButton" Classes="ghost" Content="Choose .gguf…" />
                            <TextBlock x:Name="GgufPathLabel" Classes="muted" VerticalAlignment="Center" Text="No model selected" />
                        </StackPanel>
                        <TextBlock Text="Context size" Classes="muted" />
                        <TextBox x:Name="ContextSizeBox" Text="4096" Width="140" HorizontalAlignment="Left" />
                        <TextBlock Classes="muted" TextWrapping="Wrap"
                                   Text="Jobomate runs the model on a loopback OpenAI-compatible endpoint. It never downloads models for you." />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="TestLlmButton" Classes="accent" Content="Test connection" />
                        <TextBlock x:Name="LlmTestStatus" Classes="muted" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- Step 4: Connect email -->
                <StackPanel x:Name="Step4" Spacing="10" IsVisible="False">
                    <TextBlock TextWrapping="Wrap" Classes="muted"
                               Text="Connect the email account you'll send from. Dry-run is the default until you successfully test a real account — nothing leaves your machine before then." />
                    <StackPanel Spacing="6">
                        <RadioButton x:Name="EmailDryRun" GroupName="email" Content="Dry run (record drafts, never send) — recommended to start" IsChecked="True" />
                        <RadioButton x:Name="EmailSmtp" GroupName="email" Content="SMTP (works with Gmail app passwords and any provider)" />
                        <RadioButton x:Name="EmailGmail" GroupName="email" Content="Gmail (OAuth)" />
                        <RadioButton x:Name="EmailMicrosoft" GroupName="email" Content="Microsoft 365 (OAuth / Graph)" />
                    </StackPanel>

                    <StackPanel x:Name="SmtpPanel" Spacing="8" IsVisible="False">
                        <TextBlock Text="From address" Classes="muted" />
                        <TextBox x:Name="FromAddressBox" Watermark="you@example.com" />
                        <TextBlock Text="From name" Classes="muted" />
                        <TextBox x:Name="FromNameBox" />
                        <Grid ColumnDefinitions="*,Auto" >
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="SMTP host" Classes="muted" />
                                <TextBox x:Name="SmtpHostBox" Watermark="smtp.gmail.com" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="8" Margin="10,0,0,0">
                                <TextBlock Text="Port" Classes="muted" />
                                <TextBox x:Name="SmtpPortBox" Text="587" Width="90" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Username" Classes="muted" />
                        <TextBox x:Name="SmtpUserBox" />
                        <TextBlock Text="Password / app password (stored in Keychain)" Classes="muted" />
                        <TextBox x:Name="SmtpPassBox" PasswordChar="•" />
                    </StackPanel>

                    <StackPanel x:Name="OAuthPanel" Spacing="8" IsVisible="False">
                        <TextBlock Text="From address" Classes="muted" />
                        <TextBox x:Name="OAuthFromBox" Watermark="you@example.com" />
                        <TextBlock Text="OAuth client id (your registered app)" Classes="muted" />
                        <TextBox x:Name="OAuthClientIdBox" />
                        <TextBlock Classes="muted" TextWrapping="Wrap"
                                   Text="Sign-in opens your browser. Tokens are stored in the Keychain and refreshed automatically." />
                        <Button x:Name="OAuthSignInButton" Classes="ghost" Content="Sign in" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="TestEmailButton" Classes="accent" Content="Test account" />
                        <TextBlock x:Name="EmailTestStatus" Classes="muted" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- Step 5: Mode -->
                <StackPanel x:Name="Step5" Spacing="12" IsVisible="False">
                    <TextBlock TextWrapping="Wrap" Classes="muted" Text="Choose how you want to start. You can switch modes anytime." />
                    <RadioButton x:Name="ModeRecent" GroupName="mode" IsChecked="True">
                        <StackPanel>
                            <TextBlock Text="Recent job postings" FontWeight="SemiBold" Foreground="{DynamicResource JobTextBrush}" />
                            <TextBlock Classes="muted" TextWrapping="Wrap" Text="Find and rank suitable recent roles, classify language strictly, draft tailored emails + cover letters." />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="ModeUnsolicited" GroupName="mode">
                        <StackPanel>
                            <TextBlock Text="Unsolicited applications" FontWeight="SemiBold" Foreground="{DynamicResource JobTextBrush}" />
                            <TextBlock Classes="muted" TextWrapping="Wrap" Text="Research suitable employers, find official recruiting emails, draft company-specific speculative applications." />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Panel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="28,14" Background="{DynamicResource JobPanelBrush}"
                BorderBrush="{DynamicResource JobBorderBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button x:Name="BackButton" Classes="ghost" Content="Back" IsVisible="False" />
                <TextBlock x:Name="FooterNote" Grid.Column="1" Classes="muted" VerticalAlignment="Center" Margin="14,0" />
                <Button x:Name="NextButton" Grid.Column="2" Classes="accent" Content="Next" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
