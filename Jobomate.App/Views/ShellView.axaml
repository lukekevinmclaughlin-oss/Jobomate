<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Jobomate.Views.ShellView">
    <Grid ColumnDefinitions="208,*,Auto">
        <Border Grid.Column="0" Background="{DynamicResource JobPanelBrush}"
                BorderBrush="{DynamicResource JobBorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel Spacing="4" Margin="12,16">
                <Button x:Name="NavAssistant" Classes="nav active" Content="Assistant" />
                <Button x:Name="NavDetails" Classes="nav" Content="Details &amp; settings" />
                <Button x:Name="NavSidecar" Classes="nav" Content="Activity sidecar" />
                <Border Height="1" Background="{DynamicResource JobBorderBrush}" Margin="2,12" />
                <TextBlock Text="QUICK START" Classes="muted" FontSize="11" Margin="6,0,0,4" />
                <Button x:Name="NavRecent" Classes="nav" Content="①  Recent job postings" />
                <Button x:Name="NavUnsolicited" Classes="nav" Content="②  Unsolicited applications" />
            </StackPanel>
        </Border>

        <ContentControl Grid.Column="1" x:Name="ShellContent" />

        <Border Grid.Column="2" x:Name="SidecarPane" Width="330" IsVisible="False"
                Background="{DynamicResource JobPanelBrush}"
                BorderBrush="{DynamicResource JobBorderBrush}" BorderThickness="1,0,0,0">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Padding="12,8" BorderBrush="{DynamicResource JobBorderBrush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Activity" FontWeight="SemiBold" Foreground="{DynamicResource JobTextBrush}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" x:Name="SidecarCloseButton" Classes="ghost" Content="✕" Width="30" Height="28" Padding="0" />
                    </Grid>
                </Border>
                <ContentControl Grid.Row="1" x:Name="SidecarHost" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
